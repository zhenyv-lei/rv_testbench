diff -ruN minios/user/meltdown_us.c minios/user/meltdown_us.c
--- minios/user/meltdown_us.c	1970-01-01 08:00:00.000000000 +0800
+++ minios/user/meltdown_us.c	2026-07-08 19:33:46.793735622 +0800
@@ -0,0 +1,64 @@
+#include "user.h"
+
+#define PROBE_STRIDE 64
+#define PROBE_VALUES 256
+#define PROBE_BYTES (PROBE_VALUES * PROBE_STRIDE)
+#define ATTEMPTS 8
+
+static unsigned char* probe;
+
+__attribute__((noinline)) static void run_faulting_gadget(unsigned long secret_va) {
+    unsigned long recover_pc;
+
+    asm volatile("la %0, meltdown_us_recover_label" : "=r"(recover_pc));
+
+    if (meltdown_arm((void*)recover_pc) < 0) {
+        printf("meltdown-us: arm failed\n");
+        exit(1);
+    }
+
+    asm volatile(
+        ".align 2\n"
+        "meltdown_us_fault_label:\n"
+        "fence rw, rw\n"
+        "lb   t0, 0(%0)\n"
+        "slli t0, t0, 6\n"
+        "add  t0, t0, %1\n"
+        "ld   zero, 0(t0)\n"
+        "meltdown_us_recover_label:\n"
+        "nop\n"
+        :
+        : "r"(secret_va), "r"(probe)
+        : "t0", "memory");
+}
+
+int main(void) {
+    unsigned long secret_va = meltdown_setup();
+    unsigned char* mem;
+
+    if (secret_va == (unsigned long)-1) {
+        printf("meltdown-us: setup failed\n");
+        exit(1);
+    }
+
+    mem = sbrk(PROBE_BYTES + 128);
+    if (mem == (void*)-1) {
+        printf("meltdown-us: sbrk failed\n");
+        exit(1);
+    }
+    probe = (unsigned char*)(((unsigned long)mem + 63) & ~63UL);
+
+    for (unsigned long i = 0; i < PROBE_BYTES; i = i + PROBE_STRIDE) {
+        probe[i] = (unsigned char)i;
+    }
+
+    printf("meltdown-us: secret_va=0x%x attempts=%d\n", (unsigned int)secret_va, ATTEMPTS);
+
+    for (int attempt = 0; attempt < ATTEMPTS; attempt = attempt + 1) {
+        run_faulting_gadget(secret_va);
+    }
+
+    printf("meltdown-us: fault recovery ok\n");
+    printf("meltdown-us: done\n");
+    exit(0);
+}
