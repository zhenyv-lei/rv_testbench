@@ -18,6 +18,10 @@
     li t0, 0x800
     csrs mstatus, t0
     li t0, 0xffff
+#if MELTDOWN_US_MMODE_CYCLE_TIMING || MELTDOWN_US_PMP_FAULT
+    li t1, ~(1 << 9)
+    and t0, t0, t1
+#endif
     csrw medeleg, t0
     # Delegate supervisor/user interrupts, but keep machine timer interrupts
     # in M-mode so timervec can re-arm mtimecmp and notify S-mode via SSIP.
@@ -30,6 +34,10 @@
     csrw pmpaddr0, t0
     li t0, 0x0f
     csrw pmpcfg0, t0
+#if MELTDOWN_US_ENABLE_COUNTEREN
+    li t0, 0x7
+    csrw mcounteren, t0
+#endif
     mret
 
 timerinit:
@@ -74,19 +82,37 @@
     sd t2, 32(t1)
     csrw mscratch, t1
 
-    la t0, timervec
+    la t0, machinevec
     csrw mtvec, t0
     li t0, (1 << 7)
     csrs mie, t0
     ret
 
 .align 4
-timervec:
+machinevec:
     csrrw a0, mscratch, a0
     sd a1, 0(a0)
     sd a2, 8(a0)
     sd a3, 16(a0)
+    csrr a1, mcause
+    li a2, 0x8000000000000007
+    beq a1, a2, timervec
+#if MELTDOWN_US_MMODE_CYCLE_TIMING
+    li a2, 9
+    beq a1, a2, mcycle_service
+#endif
+#if MELTDOWN_US_PMP_FAULT
+    li a2, 9
+    beq a1, a2, pmp_service
+#if MELTDOWN_US_MMODE_FAULT_SKIP
+    li a2, 5
+    beq a1, a2, mmode_fault_skip
+#endif
+#endif
+1:
+    j 1b
 
+timervec:
     ld a1, 24(a0)
     ld a2, 32(a0)
     ld a3, 0(a1)
@@ -102,6 +128,86 @@
     csrrw a0, mscratch, a0
     mret
 
+#if MELTDOWN_US_MMODE_CYCLE_TIMING
+mcycle_service:
+    li a1, 0x4d435943
+    bne a7, a1, mcycle_service_unknown
+    csrr a1, mcycle
+    csrr a2, mepc
+    addi a2, a2, 4
+    csrw mepc, a2
+    mv a2, a0
+    ld a3, 16(a2)
+    csrw mscratch, a2
+    mv a0, a1
+    ld a1, 0(a2)
+    ld a2, 8(a2)
+    mret
+mcycle_service_unknown:
+#if MELTDOWN_US_PMP_FAULT
+    j pmp_service
+#else
+    j 1b
+#endif
+#endif
+
+#if MELTDOWN_US_PMP_FAULT
+pmp_service:
+    li a1, 0x504d5046
+    bne a7, a1, 1f
+    beqz a6, pmp_clear_secret
+
+    srli a1, a6, 2
+    csrw pmpaddr0, a1
+    li a1, 4096
+    add a1, a6, a1
+    srli a1, a1, 2
+    csrw pmpaddr1, a1
+    li a1, -1
+    csrw pmpaddr2, a1
+    li a1, 0x0f080f
+    csrw pmpcfg0, a1
+    fence
+    j pmp_service_done
+
+pmp_clear_secret:
+    li a1, -1
+    csrw pmpaddr0, a1
+    csrw pmpaddr1, zero
+    csrw pmpaddr2, zero
+    li a1, 0x0f
+    csrw pmpcfg0, a1
+    fence
+
+pmp_service_done:
+    csrr a1, mepc
+    addi a1, a1, 4
+    csrw mepc, a1
+    mv a2, a0
+    ld a3, 16(a2)
+    csrw mscratch, a2
+    li a0, 0
+    ld a1, 0(a2)
+    ld a2, 8(a2)
+    mret
+1:
+    j 1b
+
+#if MELTDOWN_US_MMODE_FAULT_SKIP
+mmode_fault_skip:
+    csrr a1, mepc
+    addi a1, a1, 4
+    csrw mepc, a1
+    mv a2, a0
+    ld a3, 16(a2)
+    csrw mscratch, a2
+    li a0, 0
+    ld a1, 0(a2)
+    ld a2, 8(a2)
+    mret
+#endif
+#endif
+
 supervisor_entry:
     call main
 1:
