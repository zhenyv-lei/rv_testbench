+static void meltdown_flush_line(uint64 addr) {
+    uint64 set = (addr >> 6) & (MELTDOWN_L1_SETS - 1);
+    uint64 base = meltdown_eviction_base();
+
+    for (uint64 way = 0; way < MELTDOWN_EVICTION_MULTIPLIER * MELTDOWN_L1_WAYS; way = way + 1) {
+        uint64 p = base + (set << 6) + (way * MELTDOWN_L1_SET_SPAN_BYTES);
+        meltdown_sink = meltdown_sink ^ *(volatile uchar*)p;
+    }
+    meltdown_fence_all();
+}
+
+static uint64 meltdown_probe_time(uint64 addr) {
+    volatile uchar* p = (volatile uchar*)addr;
+    meltdown_fence_all();
+    uint64 start = meltdown_cycle();
+    uchar value = 0;
+    for (int rep = 0; rep < MELTDOWN_US_TIME_REPS; rep = rep + 1) {
+        value = value ^ *p;
+    }
+    meltdown_fence_all();
+    meltdown_sink = meltdown_sink ^ value;
+    return meltdown_cycle() - start;
+}
+
+static int meltdown_probe_mix(int i) {
+    return ((i * 167) + 13) & 255;
+}
+
+static uint64 sys_meltdown_calibrate(void) {
+    struct proc* p = myproc();
+    uint64 probe_va;
+    uint64 hot_pa;
+    uint64 cold_pa;
+    uint64 hit = ~(uint64)0;
+    uint64 miss = 0;
+
+    if (argaddr(0, &probe_va) < 0) {
+        return 0;
+    }
+
+    hot_pa = meltdown_probe_pa(p, probe_va, 0);
+    cold_pa = meltdown_probe_pa(p, probe_va, 1);
+    if (hot_pa == 0 || cold_pa == 0) {
+        return 0;
+    }
+
+    for (int rep = 0; rep < MELTDOWN_US_CAL_REPS; rep = rep + 1) {
+        uint64 sample_hit;
+        uint64 sample_miss;
+
+        meltdown_sink = meltdown_sink ^ *(volatile uchar*)hot_pa;
+        sample_hit = meltdown_probe_time(hot_pa);
+        if (sample_hit < hit) {
+            hit = sample_hit;
+        }
+
+        meltdown_flush_line(cold_pa);
+        sample_miss = meltdown_probe_time(cold_pa);
+        if (sample_miss > miss) {
+            miss = sample_miss;
+        }
+    }
+    return ((hit & 0xffffffffUL) << 32) | (miss & 0xffffffffUL);
+}
+
+static uint64 sys_meltdown_flush_probe(void) {
+    struct proc* p = myproc();
+    uint64 probe_va;
+
+    if (argaddr(0, &probe_va) < 0) {
+        return (uint64)-1;
+    }
+
+    for (int i = 0; i < MELTDOWN_PROBE_VALUES; i = i + 1) {
+        uint64 pa = meltdown_probe_pa(p, probe_va, i);
+        if (pa == 0) {
+            return (uint64)-1;
+        }
+        meltdown_flush_line(pa);
+    }
+    return 0;
+}
+
+static uint64 sys_meltdown_probe(void) {
+    struct proc* p = myproc();
+    uint64 probe_va;
+    uint64 threshold;
+    uint64 hits_va;
+    uint32 hits[MELTDOWN_PROBE_VALUES];
+
+    if (argaddr(0, &probe_va) < 0 || argaddr(1, &threshold) < 0 ||
+        argaddr(2, &hits_va) < 0) {
+        return (uint64)-1;
+    }
+
+    memset(hits, 0, sizeof(hits));
+    for (int i = 0; i < MELTDOWN_PROBE_VALUES; i = i + 1) {
+        int mixed = meltdown_probe_mix(i);
+        uint64 pa = meltdown_probe_pa(p, probe_va, mixed);
+        uint64 elapsed;
+
+        if (pa == 0) {
+            return (uint64)-1;
+        }
+        elapsed = meltdown_probe_time(pa);
+        if (elapsed <= threshold) {
+            hits[mixed] = hits[mixed] + 1;
+        }
+    }
+
+    if (copyout(p->pt, hits_va, (char*)hits, sizeof(hits)) < 0) {
+        return (uint64)-1;
+    }
+    return 0;
+}
+
+static uint64 sys_meltdown_probe_time_one(void) {
+    struct proc* p = myproc();
+    uint64 probe_va;
+    int index;
+    uint64 pa;
+
+    if (argaddr(0, &probe_va) < 0 || argint(1, &index) < 0) {
+        return (uint64)-1;
+    }
+    if (index < 0 || index >= MELTDOWN_PROBE_VALUES) {
+        return (uint64)-1;
+    }
+
+    pa = meltdown_probe_pa(p, probe_va, index);
+    if (pa == 0) {
+        return (uint64)-1;
+    }
+    return meltdown_probe_time(pa);
+}
+
+static uint64 sys_meltdown_residency(void) {
+    struct proc* p = myproc();
+    uint64 probe_va;
+    uint64 probe53_pa;
+    uint64 probe0_pa;
+    uint64 secret_time;
+    uint64 probe53_time;
+    uint64 probe0_time;
+
+    if (argaddr(0, &probe_va) < 0) {
+        return (uint64)-1;
+    }
+
+    probe53_pa = meltdown_probe_pa(p, probe_va, 0x53);
+    probe0_pa = meltdown_probe_pa(p, probe_va, 0);
+    if (probe53_pa == 0 || probe0_pa == 0) {
+        return (uint64)-1;
+    }
+
+    secret_time = meltdown_probe_time((uint64)meltdown_secret_page);
+    probe53_time = meltdown_probe_time(probe53_pa);
+    probe0_time = meltdown_probe_time(probe0_pa);
+
+    return ((secret_time & 0xffffUL) << 32) |
+           ((probe53_time & 0xffffUL) << 16) |
+           (probe0_time & 0xffffUL);
+}
