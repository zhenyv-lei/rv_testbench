+}
+
+static inline uint64 mmode_pmp_secret(uint64 secret_pa) {
+#if MELTDOWN_US_PMP_FAULT
+    register uint64 a0 asm("a0");
+    register uint64 a6 asm("a6") = secret_pa;
+    register uint64 a7 asm("a7") = 0x504d5046UL;
+
+    asm volatile("ecall" : "=r"(a0) : "r"(a6), "r"(a7) : "memory");
+    return a0;
+#else
+    (void)secret_pa;
+    return (uint64)-1;
+#endif
+}
+
+static uint64 sys_meltdown_pmp_secret(void) {
+    int deny;
+
+    if (argint(0, &deny) < 0) {
+        return (uint64)-1;
+    }
+#if MELTDOWN_US_PMP_FAULT
+    if (deny) {
+        return mmode_pmp_secret((uint64)meltdown_secret_page);
+    }
+    return mmode_pmp_secret(0);
+#else
+    return (uint64)-1;
+#endif
+}
+
+static inline void meltdown_fence_all(void) {
+    asm volatile("fence rw, rw" ::: "memory");
+}
+
+static uint64 sys_meltdown_arm(void) {
