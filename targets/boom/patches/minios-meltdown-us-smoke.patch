@@ -13,6 +13,10 @@
 #define MAXPATH 128
 #define MAXARG 16
 #define MAX_DIRENTS 64
+#define MELTDOWN_SECRET_VA (1UL << 29)
+#define MELTDOWN_SECRET_VALUE 0x53
+
+static uchar meltdown_secret_page[PGSIZE] __attribute__((aligned(PGSIZE)));
 
 static uint64 argraw(int n) {
     struct proc* p = myproc();
@@ -430,6 +434,40 @@
     return 0;
 }
 
+static uint64 sys_meltdown_setup(void) {
+    struct proc* p = myproc();
+    pte_t* pte;
+
+    memset(meltdown_secret_page, 0, sizeof(meltdown_secret_page));
+    meltdown_secret_page[0] = MELTDOWN_SECRET_VALUE;
+
+    pte = walk(p->pt, MELTDOWN_SECRET_VA, 0);
+    if (pte != NULL && (*pte & RISCV_PTE_V) != 0) {
+        if (PTE2PA(*pte) == (uint64)meltdown_secret_page &&
+            ((*pte & RISCV_PTE_U) == 0)) {
+            return MELTDOWN_SECRET_VA;
+        }
+        return (uint64)-1;
+    }
+
+    if (mappages(p->pt, MELTDOWN_SECRET_VA, PGSIZE, (uint64)meltdown_secret_page,
+                 RISCV_PTE_R) != 0) {
+        return (uint64)-1;
+    }
+    sfence_vma();
+    return MELTDOWN_SECRET_VA;
+}
+
+static uint64 sys_meltdown_arm(void) {
+    uint64 recover_pc;
+
+    if (argaddr(0, &recover_pc) < 0) {
+        return (uint64)-1;
+    }
+    myproc()->meltdown_recover_epc = recover_pc;
+    return 0;
+}
+
 static uint64 sys_mmap(void) {
     uint64 addr;
     uint64 length;
@@ -512,6 +550,8 @@
     [SYS_mremap] sys_mremap,
     [SYS_mkdir] sys_mkdir,
     [SYS_getprocinfo] sys_getprocinfo,
+    [SYS_meltdown_setup] sys_meltdown_setup,
+    [SYS_meltdown_arm] sys_meltdown_arm,
 };
 
