+static uint64 sys_meltdown_setup(void) {
+    struct proc* p = myproc();
+    pte_t* pte;
+    pte_t* alias_pte;
+    uint64 secret_perm = RISCV_PTE_R;
+#if MELTDOWN_US_PMP_FAULT
+    secret_perm = RISCV_PTE_R | RISCV_PTE_U;
+#endif
+
+    memset(meltdown_secret_page, 0, sizeof(meltdown_secret_page));
+    meltdown_secret_page[0] = MELTDOWN_SECRET_VALUE;
+
+    pte = walk(p->pt, MELTDOWN_SECRET_VA, 0);
+    if (pte != NULL && (*pte & RISCV_PTE_V) != 0) {
+        if (PTE2PA(*pte) == (uint64)meltdown_secret_page &&
+            ((*pte & (RISCV_PTE_R | RISCV_PTE_U)) == secret_perm)) {
+            alias_pte = walk(p->pt, MELTDOWN_SECRET_ALIAS_VA, 0);
+            if (alias_pte == NULL || (*alias_pte & RISCV_PTE_V) == 0) {
+                if (mappages(p->pt, MELTDOWN_SECRET_ALIAS_VA, PGSIZE,
+                             (uint64)meltdown_secret_page,
+                             RISCV_PTE_R | RISCV_PTE_U) != 0) {
+                    return (uint64)-1;
+                }
+            } else if (PTE2PA(*alias_pte) != (uint64)meltdown_secret_page ||
+                       ((*alias_pte & RISCV_PTE_U) == 0)) {
+                return (uint64)-1;
+            }
+            sfence_vma();
+            return MELTDOWN_SECRET_VA;
+        }
+        return (uint64)-1;
+    }
+
+    if (mappages(p->pt, MELTDOWN_SECRET_VA, PGSIZE, (uint64)meltdown_secret_page,
+                 secret_perm) != 0) {
+        return (uint64)-1;
+    }
+    if (mappages(p->pt, MELTDOWN_SECRET_ALIAS_VA, PGSIZE,
+                 (uint64)meltdown_secret_page, RISCV_PTE_R | RISCV_PTE_U) != 0) {
+        uvmunmap(p->pt, MELTDOWN_SECRET_VA, 1, 0);
+        return (uint64)-1;
+    }
+    sfence_vma();
+    return MELTDOWN_SECRET_VA;
+}
+
+static uint64 sys_meltdown_alias(void) {
