+static inline uint64 mmode_mcycle(void) {
+    register uint64 a0 asm("a0");
+    register uint64 a7 asm("a7") = 0x4d435943UL;
+
+    asm volatile("ecall" : "=r"(a0) : "r"(a7) : "memory");
+    return a0;
+}
+
+static inline uint64 meltdown_cycle(void) {
+#if MELTDOWN_US_MMODE_CYCLE_TIMING
+    return mmode_mcycle();
+#elif MELTDOWN_US_MCYCLE_TIMING
+    return r_mcycle();
+#elif MELTDOWN_US_CYCLE_TIMING
+    return r_cycle();
+#else
+    #if defined(PLATFORM_XIANGSHAN) || defined(PLATFORM_NEMU)
+    volatile uint64* mtime = (volatile uint64*)0x3800bff8UL;
+    #else
+    volatile uint64* mtime = (volatile uint64*)0x0200bff8UL;
+    #endif
+    return *mtime;
+#endif
